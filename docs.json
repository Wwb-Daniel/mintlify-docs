{
  "$schema": "https://mintlify.com/docs.json",
  "name": "CinemaDB",
  "theme": "almond",
  "colors": {
    "primary": "#E50914",
    "light": "#FF1F2D",
    "dark": "#B20710"
  },
  "favicon": "/favicon.svg",
  "navbar": {
    "primary": {
      "type": "button",
      "label": "Ir a CinemaDB",
      "href": "https://www.cinemadb.club"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Guía de Usuario",
        "groups": [
          {
            "group": "Introducción",
            "pages": [
              "introduccion",
              "primeros-pasos"
            ]
          },
          {
            "group": "Contenido",
            "pages": [
              "contenido/peliculas",
              "contenido/series",
              "contenido/anime",
              "contenido/tv-en-vivo"
            ]
          },
          {
            "group": "Tu Cuenta",
            "pages": [
              "cuenta/registro-e-inicio-sesion",
              "cuenta/perfil-y-configuracion",
              "cuenta/favoritos-e-historial",
              "cuenta/planes-premium"
            ]
          },
          {
            "group": "Aplicaciones",
            "pages": [
              "apps/descarga-android",
              "apps/windows",
              "apps/ios-pwa"
            ]
          },
          {
            "group": "Ayuda",
            "pages": [
              "ayuda/preguntas-frecuentes",
              "ayuda/compatibilidad-dispositivos",
              "ayuda/comunidad-y-discord"
            ]
          }
        ]
      }
    ]
  },
  "footer": {
    "socials": {
      "discord": "https://discord.gg/cinemadb"
    }
  }
}
